# 複製這份成 .streamlit/secrets.toml 並填入實際值。
# .streamlit/secrets.toml 已被 .gitignore 排除，不會進 repo。
# 雲端部署時，把同樣的內容貼到 Streamlit Cloud → App settings → Secrets。

# 進站密碼
app_password = "請改成你的密碼"

# 「資料 repo」（放 4 個 CSV 的那個 private repo），格式：擁有者/儲存庫名
data_repo = "your-github-username/collection-data"

# GitHub Personal Access Token（fine-grained，只授權「資料 repo」的 Contents 讀寫）
github_token = "github_pat_xxxxxxxxxxxxxxxx"
